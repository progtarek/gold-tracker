# Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Your Telegram chat ID (get from @userinfobot on Telegram)
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Twelve Data API key - get free at https://twelvedata.com/pricing (800 requests/day, no credit card needed)
TWELVE_DATA_API_KEY=your-twelve-data-api-key-here

# Price alerts (set to 0 to disable)
# Alert when price goes ABOVE this amount (USD per ounce)
ALERT_PRICE_ABOVE=3000

# Alert when price goes BELOW this amount (USD per ounce)
ALERT_PRICE_BELOW=0

# How often to check and send updates (minutes) - 60 (1 hour) recommended
UPDATE_INTERVAL_MINUTES=60
