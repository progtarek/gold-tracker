# Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Your Telegram chat ID (get from @userinfobot on Telegram)
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# FCS API key - get free at https://fcsapi.com/pricing-free (100 requests/day, no credit card needed)
FCS_API_KEY=your-fcs-api-key-here

# Price alerts (set to 0 to disable)
# Alert when price goes ABOVE this amount (USD per ounce)
ALERT_PRICE_ABOVE=3000

# Alert when price goes BELOW this amount (USD per ounce)
ALERT_PRICE_BELOW=0

# How often to check and send updates (minutes) - 180 (3 hours) recommended to stay under API limit
UPDATE_INTERVAL_MINUTES=180
